#!/usr/bin/env -S uv run --script
# /// script
# dependencies = [
#   "tomlkit",
# ]
# ///

import subprocess
from pathlib import Path

import tomlkit

enabled = {{ if .local_llm.enabled }}True{{ else }}False{{ end }}
model_alias = {{ .local_llm.modelAlias | quote }}
server_host = {{ .local_llm.serverHost | quote }}
server_port = {{ .local_llm.serverPort | quote }}
is_wsl2 = {{ if .is_wsl2 }}True{{ else }}False{{ end }}
path = Path.home() / ".codex/local.config.toml"

def detect_wsl2_host() -> str:
    try:
        result = subprocess.run(
            ["ip", "route", "show", "default"],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except OSError:
        return server_host

    for line in result.stdout.splitlines():
        fields = line.split()
        if fields[:1] == ["default"] and "via" in fields:
            via_index = fields.index("via")
            if via_index + 1 < len(fields):
                return fields[via_index + 1]

    return server_host

def build_config():
    if not enabled:
        if path.exists():
            path.unlink()
        return
    host = detect_wsl2_host() if is_wsl2 else server_host
    doc = tomlkit.table()

    doc["model_provider"] = "local"
    doc["model"] = model_alias
    doc["web_search"] = "disabled"

    local_provider = tomlkit.table()
    local_provider["name"] = "local"
    local_provider["base_url"] = f"http://{host}:{server_port}/v1"
    local_provider["wire_api"] = "responses"
    local_provider["stream_idle_timeout_ms"] = 10000000

    model_providers = tomlkit.table()
    model_providers["local"] = local_provider
    doc["model_providers"] = model_providers

    features = tomlkit.table()
    features["image_generation"] = False
    features["apps"] = False
    doc["features"] = features

    path.write_text(tomlkit.dumps(doc))

build_config()
