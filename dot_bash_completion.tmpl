# Heavy completions are generated by generate-bash-completion-cache.sh during
# chezmoi apply. Add new cached completions there, not here.
for f in "${XDG_CACHE_HOME:-$HOME/.cache}"/bash-completion/generated/*.bash; do
    [ -r "$f" ] && source "$f"
done

# terraform and etc.
while read cmd
do
    if command -v $cmd &> /dev/null; then
        complete -C $(command -v $cmd) $cmd
    fi
done << EOF
terraform
terragrunt
tofu
EOF

# git
if [ -f ~/.git-completion.sh ]; then
    source ~/.git-completion.sh
fi

# direnv
if command -v direnv &> /dev/null; then
    eval "$(direnv hook bash)"
fi

{{ completion "bash" }}
