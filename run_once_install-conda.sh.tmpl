#!/usr/bin/env bash

set -euo pipefail

MINIFORGE_VERSION=26.1.1-3
MINIFORGE="Miniforge3-$(uname)-$(uname -m)"
cd /tmp
curl -sSLO "https://github.com/conda-forge/miniforge/releases/download/${MINIFORGE_VERSION}/${MINIFORGE}.sh"
sha256sum -c {{ joinPath .chezmoi.sourceDir "files/${MINIFORGE}.checksum" }} || exit 1
echo "install miniforge"
bash ${MINIFORGE}.sh -b -u
cd - &> /dev/null

if ! command -v conda &>/dev/null; then
    source ~/miniforge3/etc/profile.d/conda.sh
fi
